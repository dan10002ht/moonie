# Host port 5440 (5432/5433 đã bị container dev khác chiếm trên máy này)
DATABASE_URL=postgres://mooni:mooni@localhost:5440/mooni?sslmode=disable
# JWT_SECRET: khoá HMAC ký JWT phiên admin. BẮT BUỘC đặt, ≥32 ký tự, KHÔNG dùng
# giá trị placeholder. Server sẽ từ chối khởi động nếu rỗng/quá ngắn/placeholder.
# Sinh secret mạnh: openssl rand -base64 48
JWT_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TRUSTED_PROXIES: danh sách IP/CIDR của reverse proxy tin cậy (Caddy/Next),
# phân tách bằng dấu phẩy. Chỉ khi peer TCP nằm trong danh sách này thì API mới
# đọc X-Forwarded-For để lấy IP client thật cho rate limit (leads 20/phút,
# login 10/phút mỗi IP). RỖNG = không tin proxy nào → rate limit theo RemoteAddr
# (default an toàn cho dev; chống spoof header). Production đặt IP/subnet nội bộ
# của Next/Caddy, ví dụ: TRUSTED_PROXIES=172.18.0.0/16
# Ví dụ nhiều mục: TRUSTED_PROXIES=10.0.0.0/8,172.16.0.5
TRUSTED_PROXIES=
# ALLOWED_ORIGIN: origin (scheme://host[:port]) được phép gửi request GHI (POST/
# PUT/PATCH/DELETE) tới route admin/auth — CSRF defense-in-depth (L4, ngoài cookie
# SameSite=Lax). Nếu header Origin CÓ mặt mà KHÔNG khớp danh sách này → 403.
# RỖNG = KHÔNG kiểm tra Origin (an toàn cho dev/test, không phá). Production BẮT
# BUỘC đặt origin site thật, ví dụ: ALLOWED_ORIGIN=https://mooni.vn
# Nhiều origin: phân tách bằng dấu phẩy, ví dụ ALLOWED_ORIGIN=https://mooni.vn,https://www.mooni.vn
ALLOWED_ORIGIN=

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION — biến bổ sung cho docker-compose.prod.yml (xem docs/runbook.md).
# Các biến ${VAR:?} là BẮT BUỘC: thiếu thì `docker compose ... up/config` DỪNG NGAY.
# Ở production, DATABASE_URL do compose tự dựng từ POSTGRES_* (không set tay biến này).
# ─────────────────────────────────────────────────────────────────────────────
# DOMAIN: domain chính (KHÔNG kèm scheme). Caddy auto HTTPS + build NEXT_PUBLIC_API_BASE.
DOMAIN=mooni.vn
# ACME_EMAIL: email đăng ký Let's Encrypt (nhận cảnh báo hết hạn cert).
ACME_EMAIL=ops@mooni.vn
# POSTGRES_*: thông tin DB nội bộ (postgres KHÔNG expose port ra host ở prod).
POSTGRES_USER=mooni
POSTGRES_DB=mooni
# POSTGRES_PASSWORD: mật khẩu Postgres — mạnh, không mặc định. openssl rand -base64 24
POSTGRES_PASSWORD=
# SEED_ADMIN_PASSWORD: mật khẩu admin khởi tạo — ≥12 ký tự, KHÔNG phải 'mooni-admin'
# (seed production từ chối mặc định/quá ngắn). openssl rand -base64 18
SEED_ADMIN_PASSWORD=
# Prod: TRUSTED_PROXIES nên = subnet mạng compose (default 172.28.0.0/16 nếu để trống
# ở compose.prod). ALLOWED_ORIGIN = https://<DOMAIN>.
